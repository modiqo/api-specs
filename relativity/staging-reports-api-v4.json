  "components": {
    "schemas": {
      "DirectoryListRequest": {
        "required": ["path"],
        "type": "object",
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "paging": {
            "$ref": "#/components/schemas/Page"
          }
        },
        "additionalProperties": false
      },
      "DirectoryReportRequest": {
        "required": ["depth", "path"],
        "type": "object",
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "includeFiles": {
            "type": "boolean"
          },
          "depth": {
            "$ref": "#/components/schemas/ReportDepth"
          },
          "useSnapshot": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ReportDepth": {
        "enum": [
          "TopLevelOnly",
          "OneLevelDeep",
          "TwoLevelsDeep",
          "FullHierarchy"
        ],
        "type": "string"
      },
      "BillableSummaryReport": {
        "type": "object",
        "properties": {
          "container": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "BillableSummaryReportPageResponse": {
        "type": "object",
        "properties": {
          "reports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillableSummaryReport"
            },
            "nullable": true
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ReportJobResponse": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string",
            "format": "uuid"
          },
          "path": {
            "type": "string",
            "nullable": true
          },
          "createdOn": {
            "type": "string",
            "format": "date-time"
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "includeFiles": {
            "type": "boolean"
          },
          "depth": {
            "$ref": "#/components/schemas/ReportDepth"
          },
          "useSnapshot": {
            "type": "boolean"
          },
          "captureStart": {
            "type": "string",
            "format": "date-time"
          },
          "captureEnd": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "ReportJobsResponse": {
        "type": "object",
        "properties": {
          "reportJobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReportJobResponse"
            },
            "nullable": true
          },
          "paging": {
            "$ref": "#/components/schemas/Page"
          }
        },
        "additionalProperties": false
      },
      "ReportResponse": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "Page": {
        "required": ["limit", "start"],
        "type": "object",
