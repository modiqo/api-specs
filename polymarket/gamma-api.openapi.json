    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Search markets, events, and profiles",
        "description": "Full-text search across markets, events, and profiles. NOTE: This endpoint requires session authentication (cookies) and is not accessible via raw API calls. Use the Gamma list endpoints with query filters as an alternative for programmatic access.",
        "tags": ["Search"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query" },
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["markets", "events", "profiles"] }, "description": "Filter by entity type" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Search results containing events, markets, tags, and profiles",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResults" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - requires session authentication"
          }
        }
      }
    },
