{
  "openapi": "3.1.0",
  "info": {
    "title": "Polymarket Gamma API",
    "description": "Markets, events, tags, series, comments, sports, search, and public profiles. This is the primary API for discovering and browsing market data. No authentication required.",
    "version": "1.0.0",
    "contact": {
      "name": "Polymarket",
      "url": "https://docs.polymarket.com"
    }
  },
  "servers": [
    {
      "url": "https://gamma-api.polymarket.com",
      "description": "Production"
    }
  ],
  "paths": {
    "/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List events",
        "description": "Fetches a list of events with various filtering and sorting options. Events are top-level containers that hold one or more markets.",
        "tags": ["Events"],
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "string" }, "description": "Filter by event ID" },
          { "name": "slug", "in": "query", "schema": { "type": "string" }, "description": "Filter by event slug" },
          { "name": "ticker", "in": "query", "schema": { "type": "string" }, "description": "Filter by event ticker" },
          { "name": "active", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by active status" },
          { "name": "closed", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by closed status" },
          { "name": "archived", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by archived status" },
          { "name": "tag_id", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag ID" },
          { "name": "tag", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag slug" },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["volume_24hr", "volume", "liquidity", "startDate", "endDate", "createdAt", "competitive"] }, "description": "Sort field" },
          { "name": "ascending", "in": "query", "schema": { "type": "boolean" }, "description": "Sort ascending (default false)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 }, "description": "Number of results per page" },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 }, "description": "Pagination offset" }
        ],
        "responses": {
          "200": {
            "description": "Array of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Event" }
                }
              }
            }
          }
        }
      }
    },
    "/events/{id}": {
      "get": {
        "operationId": "getEventById",
        "summary": "Get event by ID",
        "description": "Fetches a single event by its numeric ID.",
        "tags": ["Events"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Event ID" }
        ],
        "responses": {
          "200": {
            "description": "Event object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          }
        }
      }
    },
    "/events/slug/{slug}": {
      "get": {
        "operationId": "getEventBySlug",
        "summary": "Get event by slug",
        "description": "Fetches a single event by its URL slug.",
        "tags": ["Events"],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Event slug" }
        ],
        "responses": {
          "200": {
            "description": "Event object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          }
        }
      }
    },
    "/events/{id}/tags": {
      "get": {
        "operationId": "getEventTags",
        "summary": "Get event tags",
        "description": "Fetches tags associated with an event.",
        "tags": ["Events"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Event ID" }
        ],
        "responses": {
          "200": {
            "description": "Array of tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Tag" }
                }
              }
            }
          }
        }
      }
    },
    "/markets": {
      "get": {
        "operationId": "listMarkets",
        "summary": "List markets",
        "description": "Fetches a list of markets (individual tradable binary outcomes). Each market belongs to an event.",
        "tags": ["Markets"],
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "string" }, "description": "Filter by market ID" },
          { "name": "slug", "in": "query", "schema": { "type": "string" }, "description": "Filter by market slug" },
          { "name": "active", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by active status" },
          { "name": "closed", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by closed status" },
          { "name": "archived", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by archived status" },
          { "name": "tag_id", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag ID" },
          { "name": "tag", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag slug" },
          { "name": "conditionId", "in": "query", "schema": { "type": "string" }, "description": "Filter by condition ID (0x...)" },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["volume_24hr", "volume", "liquidity", "startDate", "endDate", "createdAt"] }, "description": "Sort field" },
          { "name": "ascending", "in": "query", "schema": { "type": "boolean" }, "description": "Sort ascending" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 }, "description": "Number of results" },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 }, "description": "Pagination offset" }
        ],
        "responses": {
          "200": {
            "description": "Array of markets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Market" }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{id}": {
      "get": {
        "operationId": "getMarketById",
