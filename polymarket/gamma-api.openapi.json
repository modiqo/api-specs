          "updatedAt": { "type": "string", "format": "date-time" },
          "competitive": { "type": "number" },
          "volume24hr": { "type": "number" },
          "volume1wk": { "type": "number" },
          "volume1mo": { "type": "number" },
          "volume1yr": { "type": "number" },
