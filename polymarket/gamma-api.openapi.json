    "/comments": {
      "get": {
        "operationId": "listComments",
        "summary": "List comments",
        "description": "Fetches comments for a specific entity. NOTE: This endpoint requires session authentication (cookies) and may not be fully accessible via raw API calls.",
        "tags": ["Comments"],
        "parameters": [
          { "name": "parent_entity_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "ID of the parent entity (event or market)" },
          { "name": "entity_entity_type", "in": "query", "required": true, "schema": { "type": "string", "enum": ["event", "market"] }, "description": "Type of entity" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Array of comments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } }
